# Yandex Object Storage — статический хостинг витрины.
# Скопируй в .env и заполни. Файл .env в .gitignore (ключи не попадут в репозиторий).

# Статический ключ доступа СЕРВИСНОГО АККАУНТА Yandex Cloud
# (Консоль → Сервисные аккаунты → твой аккаунт → Создать новый ключ → Статический ключ доступа)
YC_ACCESS_KEY_ID=YCAJ_xxxxxxxxxxxxxxxx
YC_SECRET_ACCESS_KEY=YCxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Имя бакета. Если планируешь свой домен — назови бакет РОВНО как домен (напр. sites.example.ru).
YC_BUCKET=my-design-lab
