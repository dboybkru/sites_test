---
import '@lab/motion/motion.css';
const base = import.meta.env.BASE_URL;
const runner = `${base}img/runner.webp`;
const stats = [
  { n: '2.1М', l: 'пробежек в неделю' },
  { n: '4.9★', l: 'в App Store' },
  { n: '−18%', l: 'средний пульс покоя' },
];
const features = [
  { ic: '🫀', t: 'Зоны пульса', d: 'Живая подсказка темпа: не загоняй себя и не ленись — беги в своей зоне.' },
  { ic: '🗺️', t: 'Маршруты рядом', d: 'Лучшие беговые петли вокруг тебя — по покрытию, рельефу и виду.' },
  { ic: '🔥', t: 'Мягкие цели', d: 'План адаптируется под твою форму. Пропуск — не провал, а пауза.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Stride — беги. дыши. повторяй.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">▸ Stride</a>
      <div class="links">
        <a href="#features">Возможности</a>
        <a href="#" class="btn">Скачать</a>
      </div>
    </nav>

    <header class="hero" style={`background-image: linear-gradient(90deg, rgba(15,8,5,.72), rgba(15,8,5,.25) 55%, rgba(15,8,5,.5)), url(${runner})`}>
      <div class="hero-inner m-fade-up">
        <span class="eyebrow">бег · трекинг · восстановление</span>
        <h1>Беги.<br>Дыши.<br>Повторяй.</h1>
        <p class="lead">Stride — беговой трекер, который подстраивается под тебя. Темп, пульс и маршруты — в одном спокойном интерфейсе.</p>
        <div class="cta">
          <a href="#" class="btn lg">App Store</a>
          <a href="#" class="btn lg ghost">Google Play</a>
        </div>
      </div>
    </header>

    <section class="stats">
      {stats.map((s) => (<div><b>{s.n}</b><span>{s.l}</span></div>))}
    </section>

    <section id="features" class="features">
      {features.map((f) => (
        <article class="feat"><span class="fi">{f.ic}</span><h3>{f.t}</h3><p>{f.d}</p></article>
      ))}
    </section>

    <section class="cta-band">
      <h2>Первый километр — уже сегодня</h2>
      <a href="#" class="btn lg">Скачать бесплатно</a>
    </section>

    <footer class="foot"><span>▸ Stride · 2026</span><a href="/">← на витрину</a></footer>

    <style>
      :root { --bg:#0f0805; --text:#fff; --dim:#c9bcae; --accent:#ff7a45; --font:'Sora', system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--text); font-family: var(--font); }
      .btn { display: inline-block; text-decoration: none; font-weight: 600; color: #1a0d06; background: var(--accent); border-radius: 12px; padding: 11px 22px; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn.lg { padding: 15px 30px; font-size: 1.05rem; }
      .btn.ghost { background: rgba(255,255,255,.12); color: #fff; border: 1px solid rgba(255,255,255,.35); }
      .nav { position: absolute; top: 0; left: 0; right: 0; z-index: 3; display: flex; align-items: center; justify-content: space-between; padding: 22px 6vw; }
      .logo { color: #fff; text-decoration: none; font-weight: 800; font-size: 1.3rem; }
      .links { display: flex; align-items: center; gap: 24px; }
      .links a:not(.btn) { color: rgba(255,255,255,.85); text-decoration: none; }
      .hero { position: relative; min-height: 100vh; background-size: cover; background-position: center; display: flex; align-items: center; }
      .hero-inner { max-width: 600px; padding: 0 6vw; }
      .eyebrow { color: var(--accent); font-weight: 600; font-size: .82rem; letter-spacing: .2em; text-transform: uppercase; }
      h1 { font-size: clamp(3rem, 9vw, 6rem); font-weight: 800; line-height: .98; margin: 18px 0; letter-spacing: -.03em; }
      .lead { font-size: 1.2rem; line-height: 1.6; color: var(--dim); max-width: 440px; margin: 0 0 30px; }
      .cta { display: flex; gap: 14px; flex-wrap: wrap; }
      .stats { display: flex; justify-content: center; gap: 64px; flex-wrap: wrap; max-width: 900px; margin: 0 auto; padding: 8vh 6vw; }
      .stats div { text-align: center; } .stats b { display: block; font-size: 2.6rem; font-weight: 700; color: var(--accent); } .stats span { color: var(--dim); font-size: .9rem; }
      .features { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 16px; max-width: 1040px; margin: 0 auto; padding: 0 6vw 8vh; }
      .feat { background: #1a0f0a; border: 1px solid #2c1d14; border-radius: 20px; padding: 28px; transition: transform .2s, border-color .2s; }
      .feat:hover { transform: translateY(-5px); border-color: var(--accent); }
      .fi { font-size: 1.7rem; } .feat h3 { margin: 12px 0 8px; font-size: 1.2rem; } .feat p { margin: 0; color: var(--dim); line-height: 1.6; }
      .cta-band { text-align: center; padding: 4vh 6vw 10vh; } .cta-band h2 { font-size: clamp(1.8rem,5vw,2.8rem); margin: 0 0 26px; }
      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1040px; margin: 0 auto; padding: 4vh 6vw; color: var(--dim); font-size: .9rem; border-top: 1px solid #2c1d14; }
      .foot a { color: var(--accent); text-decoration: none; }
      @media (max-width: 640px){ .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
