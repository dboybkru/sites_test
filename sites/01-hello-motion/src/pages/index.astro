---
import '@lab/motion/motion.css';
const base = import.meta.env.BASE_URL;
const runner = `${base}img/runner.webp`;

const stats = [
  { to: 2.1, dec: 1, pre: '', suf: ' М', l: 'пробежек в неделю' },
  { to: 4.9, dec: 1, pre: '', suf: '★', l: 'в App Store' },
  { to: 18,  dec: 0, pre: '−', suf: '%', l: 'средний пульс покоя' },
];

// Inline SVG (Lucide-стиль) вместо emoji — анти-паттерн «эмодзи как иконки».
const icons = {
  pulse: '<path d="M3 12h4l2 5 4-12 2 7h6"/>',
  route: '<circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/><path d="M8.5 19H14a3.5 3.5 0 0 0 0-7H10a3.5 3.5 0 0 1 0-7h5.5"/>',
  flame: '<path d="M12 3c.6 3.5-2.5 4.8-2.5 8a2.5 2.5 0 0 0 5 0c0-1-.5-2-.5-2 2 1.2 3 3 3 5a5 5 0 0 1-10 0c0-4 3.5-5.2 5.5-11Z"/>',
};
const features = [
  { ic: 'pulse', t: 'Зоны пульса', d: 'Живая подсказка темпа: не загоняй себя и не ленись — беги в своей зоне.' },
  { ic: 'route', t: 'Маршруты рядом', d: 'Лучшие беговые петли вокруг тебя — по покрытию, рельефу и виду.' },
  { ic: 'flame', t: 'Мягкие цели', d: 'План адаптируется под твою форму. Пропуск — не провал, а пауза.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Stride — беги. дыши. повторяй.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script is:inline>document.documentElement.classList.add('js')</script>
  </head>
  <body>
    <nav class="nav" data-reveal>
      <a class="logo" href="#">▸ Stride</a>
      <div class="links">
        <a href="#features">Возможности</a>
        <a href="#" class="btn" data-magnetic>Скачать</a>
      </div>
    </nav>

    <header class="hero">
      <div class="hero-bg" style={`background-image: url(${runner})`} data-parallax></div>
      <div class="hero-scrim"></div>
      <div class="hero-inner">
        <span class="eyebrow" data-reveal style="--d:0">бег · трекинг · восстановление</span>
        <h1 data-reveal style="--d:1">Беги.<br>Дыши.<br>Повторяй.</h1>
        <p class="lead" data-reveal style="--d:2">Stride — беговой трекер, который подстраивается под тебя. Темп, пульс и маршруты — в одном спокойном интерфейсе.</p>
        <div class="cta" data-reveal style="--d:3">
          <a href="#" class="btn lg" data-magnetic>App Store</a>
          <a href="#" class="btn lg ghost" data-magnetic>Google Play</a>
        </div>
      </div>
      <a href="#stats" class="scroll-cue" aria-label="Прокрутить вниз"><span></span></a>
    </header>

    <section id="stats" class="stats">
      {stats.map((s, i) => (
        <div data-reveal style={`--d:${i}`}>
          <b data-count-to={s.to} data-count-dec={s.dec} data-count-pre={s.pre} data-count-suf={s.suf}>{s.pre}0{s.suf}</b>
          <span>{s.l}</span>
        </div>
      ))}
    </section>

    <section id="features" class="features">
      {features.map((f, i) => (
        <article class="feat" data-reveal data-tilt style={`--d:${i}`}>
          <span class="fi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={icons[f.ic]} /></svg></span>
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </section>

    <section class="cta-band" data-reveal>
      <h2>Первый километр — уже сегодня</h2>
      <a href="#" class="btn lg" data-magnetic>Скачать бесплатно</a>
    </section>

    <footer class="foot"><span>▸ Stride · 2026</span><a href="/">← на витрину</a></footer>

    <style>
      :root { --bg:#0f0805; --text:#fff; --dim:#c9bcae; --accent:#ff7a45; --font:'Sora', system-ui, sans-serif; --ease:cubic-bezier(.22,1,.36,1); }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--bg); color: var(--text); font-family: var(--font); overflow-x: hidden; }
      .btn { display: inline-block; text-decoration: none; font-weight: 600; color: #1a0d06; background: var(--accent); border-radius: 12px; padding: 11px 22px; transition: transform .25s var(--ease), box-shadow .25s var(--ease); will-change: transform; }
      .btn:hover { box-shadow: 0 12px 30px -10px var(--accent); }
      .btn.lg { padding: 15px 30px; font-size: 1.05rem; }
      .btn.ghost { background: rgba(255,255,255,.12); color: #fff; border: 1px solid rgba(255,255,255,.35); }
      .nav { position: absolute; top: 0; left: 0; right: 0; z-index: 4; display: flex; align-items: center; justify-content: space-between; padding: 22px 6vw; }
      .logo { color: #fff; text-decoration: none; font-weight: 800; font-size: 1.3rem; }
      .links { display: flex; align-items: center; gap: 24px; }
      .links a:not(.btn) { color: rgba(255,255,255,.85); text-decoration: none; }

      .hero { position: relative; min-height: 100svh; display: flex; align-items: center; overflow: hidden; }
      .hero-bg { position: absolute; inset: 0; z-index: 0; background-size: cover; background-position: center; transform: scale(1.12); will-change: transform; }
      .hero-scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(90deg, rgba(15,8,5,.78), rgba(15,8,5,.28) 55%, rgba(15,8,5,.55)); }
      .hero-inner { position: relative; z-index: 2; max-width: 600px; padding: 0 6vw; }
      .eyebrow { display: inline-block; color: var(--accent); font-weight: 600; font-size: .82rem; letter-spacing: .2em; text-transform: uppercase; }
      h1 { font-size: clamp(3rem, 9vw, 6rem); font-weight: 800; line-height: .98; margin: 18px 0; letter-spacing: -.03em; }
      .lead { font-size: 1.2rem; line-height: 1.6; color: var(--dim); max-width: 440px; margin: 0 0 30px; }
      .cta { display: flex; gap: 14px; flex-wrap: wrap; }

      .scroll-cue { position: absolute; z-index: 2; bottom: 26px; left: 50%; transform: translateX(-50%); width: 26px; height: 42px; border: 2px solid rgba(255,255,255,.5); border-radius: 14px; }
      .scroll-cue span { position: absolute; top: 8px; left: 50%; width: 4px; height: 8px; margin-left: -2px; border-radius: 2px; background: #fff; animation: cue 1.6s var(--ease) infinite; }
      @keyframes cue { 0% { opacity: 0; transform: translateY(0); } 30% { opacity: 1; } 100% { opacity: 0; transform: translateY(14px); } }

      .stats { display: flex; justify-content: center; gap: 64px; flex-wrap: wrap; max-width: 900px; margin: 0 auto; padding: 12vh 6vw; }
      .stats div { text-align: center; } .stats b { display: block; font-size: 2.8rem; font-weight: 700; color: var(--accent); font-variant-numeric: tabular-nums; } .stats span { color: var(--dim); font-size: .9rem; }
      .features { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 16px; max-width: 1040px; margin: 0 auto; padding: 0 6vw 12vh; }
      .feat { background: #1a0f0a; border: 1px solid #2c1d14; border-radius: 20px; padding: 28px; transition: transform .3s var(--ease), border-color .3s var(--ease); transform-style: preserve-3d; }
      .feat:hover { border-color: var(--accent); }
      .fi { display: inline-flex; padding: 12px; border-radius: 14px; background: rgba(255,122,69,.12); color: var(--accent); }
      .fi svg { width: 26px; height: 26px; display: block; }
      .feat h3 { margin: 16px 0 8px; font-size: 1.2rem; } .feat p { margin: 0; color: var(--dim); line-height: 1.6; }
      .cta-band { text-align: center; padding: 6vh 6vw 12vh; } .cta-band h2 { font-size: clamp(1.8rem,5vw,2.8rem); margin: 0 0 26px; }
      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1040px; margin: 0 auto; padding: 4vh 6vw; color: var(--dim); font-size: .9rem; border-top: 1px solid #2c1d14; }
      .foot a { color: var(--accent); text-decoration: none; }
      @media (max-width: 640px){ .links a:not(.btn){ display:none; } }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .scroll-cue span { animation: none; }
        .hero-bg { transform: scale(1.05); }
      }
    </style>

    <script>
      import { initMotion } from '@lab/motion/motion.js';
      initMotion();
    </script>
  </body>
</html>
