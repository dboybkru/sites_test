---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';

const features = [
  { t: 'fade-up', d: 'Плавное появление снизу' },
  { t: 'float', d: 'Бесконечное парение' },
  { t: 'glow', d: 'Пульсация свечения' },
  { t: 'stagger', d: 'Поэтапный выход списка' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hello Motion</title>
  </head>
  <body>
    <main>
      <section class="hero">
        <div class="orb m-float m-glow"></div>
        <h1 class="m-fade-up">Hello&nbsp;Motion</h1>
        <p class="lead m-fade-up" style="animation-delay:0.15s">
          Первый эксперимент лаборатории. Рыба на Astro + пресеты из <code>@lab/motion</code>.
        </p>
      </section>

      <section class="grid m-stagger">
        {features.map((f, i) => (
          <div class="card" style={`--m-i:${i}`}>
            <span class="mono">.m-{f.t}</span>
            <p>{f.d}</p>
          </div>
        ))}
      </section>

      <a class="back" href="/">← на витрину</a>
    </main>

    <style>
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--color-bg); color: var(--color-text);
        font-family: var(--font-sans);
        background-image: radial-gradient(70% 50% at 50% 0%, rgba(139,92,246,0.22), transparent 70%); }
      main { max-width: 900px; margin: 0 auto; padding: var(--space-5) var(--space-3); }
      .hero { text-align: center; position: relative; padding-top: var(--space-5); margin-bottom: var(--space-5); }
      .orb { width: 110px; height: 110px; border-radius: 50%; margin: 0 auto var(--space-3);
        background: radial-gradient(circle at 30% 30%, var(--color-accent-2), var(--color-accent)); }
      h1 { font-size: var(--fs-1); margin: 0 0 var(--space-2); }
      .lead { color: var(--color-text-dim); max-width: 480px; margin: 0 auto; font-size: var(--fs-3); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: var(--space-2); }
      .card { background: var(--color-surface); border: 1px solid var(--color-border);
        border-radius: var(--radius); padding: var(--space-3); }
      .mono { font-family: var(--font-mono); color: var(--color-accent-2); }
      .card p { color: var(--color-text-dim); margin: var(--space-1) 0 0; font-size: var(--fs-small); }
      code { font-family: var(--font-mono); background: var(--color-surface-2); padding: 2px 7px; border-radius: 6px; }
      .back { display: inline-block; margin-top: var(--space-4); color: var(--color-accent); text-decoration: none; }
    </style>
  </body>
</html>
