---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';

const stats = [
  { n: '99.98%', l: 'аптайм' },
  { n: '40ms', l: 'отклик' },
  { n: '12', l: 'регионов' },
];
const rows = [
  { t: 'Edge-доставка', d: 'Контент ближе к пользователю — меньше задержка.' },
  { t: 'Наблюдаемость', d: 'Метрики, трейсы и логи из коробки.' },
  { t: 'Приватность', d: 'Данные не покидают выбранный регион.' },
];
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dark-first минимализм</title>
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">◆ Vault</a>
      <div class="links">
        <a href="#">Продукт</a><a href="#">Документация</a><a href="#">Цены</a>
        <a href="#" class="btn">Войти</a>
      </div>
    </nav>

    <header class="hero">
      <span class="eyebrow m-fade-up">инфраструктура · 2026</span>
      <h1 class="m-fade-up" style="animation-delay:.08s">Тихая мощь.<br><span class="dim">Ничего лишнего.</span></h1>
      <p class="m-fade-up" style="animation-delay:.16s">Платформа, где каждый пиксель оправдан. Тёмная тема по умолчанию, один акцент, идеальный ритм типографики.</p>
      <div class="cta m-fade-up" style="animation-delay:.24s">
        <a href="#" class="btn btn-lg">Развернуть проект</a>
        <a href="#" class="link">Читать доки →</a>
      </div>
      <div class="stats m-fade-up" style="animation-delay:.32s">
        {stats.map((s) => (<div><b>{s.n}</b><span>{s.l}</span></div>))}
      </div>
    </header>

    <section class="visual">
      <img src={`${base}img/hero.webp`} alt="Панорама города от заката до ночи" loading="lazy" />
      <div class="visual-cap">12 регионов · единый контроль-плейн</div>
    </section>

    <section class="rows">
      {rows.map((r) => (
        <article class="row">
          <span class="bullet"></span>
          <div><h3>{r.t}</h3><p>{r.d}</p></div>
          <a href="#" class="arrow">→</a>
        </article>
      ))}
    </section>

    <footer><span>◆ Vault — 2026</span><a href="/">← на витрину</a></footer>

    <style>
      :root { --bg: #0a0a0b; --panel: #131315; --line: #232327; --txt: #ededef; --dim: #8a8a92; --acc: #34d399; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--txt); font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased; letter-spacing: -.01em; }
      .btn { display: inline-block; text-decoration: none; background: var(--acc); color: #04130d; font-weight: 600;
        border-radius: 8px; padding: 9px 16px; transition: opacity .2s; }
      .btn:hover { opacity: .85; }
      .btn-lg { padding: 13px 24px; font-size: 1rem; }
      .link { color: var(--txt); text-decoration: none; font-weight: 500; align-self: center; }
      .link:hover { color: var(--acc); }
      .nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 6vw;
        border-bottom: 1px solid var(--line); position: sticky; top: 0; background: rgba(10,10,11,.8); backdrop-filter: blur(10px); z-index: 5; }
      .logo { color: var(--txt); text-decoration: none; font-weight: 700; letter-spacing: .02em; }
      .logo::first-letter { color: var(--acc); }
      .links { display: flex; gap: 28px; align-items: center; }
      .links a { color: var(--dim); text-decoration: none; font-size: .95rem; }
      .links a:hover { color: var(--txt); }
      .links a.btn { color: #04130d; }
      .hero { max-width: 760px; margin: 0 auto; padding: 16vh 6vw 10vh; }
      .eyebrow { font-family: var(--font-mono); color: var(--acc); font-size: .8rem; letter-spacing: .25em; text-transform: uppercase; }
      h1 { font-size: clamp(2.6rem, 7vw, 4.6rem); line-height: 1.05; margin: 20px 0; font-weight: 600; letter-spacing: -.03em; }
      .dim { color: var(--dim); }
      .hero > p { color: var(--dim); font-size: 1.2rem; line-height: 1.6; max-width: 520px; }
      .cta { display: flex; gap: 22px; margin-top: 30px; }
      .stats { display: flex; gap: 50px; margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--line); }
      .stats div { display: flex; flex-direction: column; gap: 4px; }
      .stats b { font-size: 1.8rem; font-weight: 600; }
      .stats span { color: var(--dim); font-size: .85rem; }
      .visual { max-width: 1100px; margin: 0 auto 4vh; padding: 0 6vw; position: relative; }
      .visual img { width: 100%; border-radius: 16px; border: 1px solid var(--line); display: block; }
      .visual-cap { position: absolute; left: calc(6vw + 18px); bottom: 18px; font-family: var(--font-mono); font-size: .82rem; color: #fff; background: rgba(10,10,11,.6); backdrop-filter: blur(8px); padding: 8px 13px; border-radius: 8px; border: 1px solid var(--line); }
      .rows { max-width: 760px; margin: 0 auto; padding: 0 6vw 12vh; display: grid; gap: 0; }
      .row { display: grid; grid-template-columns: auto 1fr auto; gap: 20px; align-items: center;
        padding: 26px 0; border-bottom: 1px solid var(--line); transition: padding-left .2s; }
      .row:hover { padding-left: 8px; }
      .bullet { width: 8px; height: 8px; border-radius: 50%; background: var(--acc); box-shadow: 0 0 12px var(--acc); }
      .row h3 { margin: 0 0 4px; font-size: 1.15rem; font-weight: 600; }
      .row p { margin: 0; color: var(--dim); }
      .arrow { color: var(--dim); text-decoration: none; font-size: 1.2rem; }
      .row:hover .arrow { color: var(--acc); }
      footer { display: flex; justify-content: space-between; align-items: center; max-width: 760px; margin: 0 auto; padding: 4vh 6vw; color: var(--dim); border-top: 1px solid var(--line); font-size: .9rem; }
      footer a { color: var(--acc); text-decoration: none; }
      @media (max-width: 640px){ .links a:not(.btn){ display:none; } .stats { gap: 28px; } }
    </style>
  </body>
</html>
