---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';

const cards = [
  { ic: '🌿', t: 'Земля', d: 'Палитра из глины, мха и песка вместо чистых цифровых цветов.' },
  { ic: '🪷', t: 'Форма', d: 'Никаких острых углов — только плавные, выросшие линии.' },
  { ic: '🍃', t: 'Воздух', d: 'Щедрые поля и крупный межстрочный ритм дают тексту дышать.' },
];
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Природная эстетика</title>
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">🌾 Terra</a>
      <div class="links">
        <a href="#values">Ценности</a><a href="#" class="btn">Связаться</a>
      </div>
    </nav>

    <header class="hero">
      <div class="intro m-fade-up">
        <p class="eyebrow">тренд · природная эстетика</p>
        <h1>Тише. Теплее. Живее.</h1>
        <p class="lead">Землистые тона, мягкие органические формы и серифная типографика создают спокойный, «аналоговый» ритм.</p>
        <div class="cta">
          <a class="btn btn-lg" href="#values">Узнать больше</a>
          <a class="btn btn-lg ghost" href="/">На витрину</a>
        </div>
      </div>
      <img class="hero-photo m-fade-up" src={`${base}img/hero.webp`} alt="Летний пейзаж: река, берёзы, луговые травы" loading="eager" />
    </header>

    <section id="values" class="cards m-stagger">
      {cards.map((c, i) => (
        <article style={`--m-i:${i}`}><div class="emoji">{c.ic}</div><h3>{c.t}</h3><p>{c.d}</p></article>
      ))}
    </section>

    <section class="band">
      <blockquote>«Природа не торопится, но всё успевает.»</blockquote>
      <a class="btn btn-lg" href="#">Начать спокойно →</a>
    </section>

    <footer><span>🌾 Terra · сделано мягко · 2026</span><a href="/">← на витрину</a></footer>

    <style>
      :root { --accent: #7a9e6e; --clay: #c08457; --sand: #efe7d6; --ink: #3a352c; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--sand); color: var(--ink); font-family: Georgia, 'Times New Roman', serif;
        background-image: radial-gradient(60% 40% at 80% 0%, #d9e2cb88, transparent 70%); }
      .btn { display: inline-block; background: var(--accent); color: var(--sand); text-decoration: none; padding: 12px 26px; border-radius: 999px; font-family: var(--font-sans); font-weight: 600; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn-lg { padding: 14px 30px; }
      .btn.ghost { background: transparent; color: var(--ink); border: 1px solid #c9bca3; }
      .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 6vw; }
      .logo { color: var(--ink); text-decoration: none; font-weight: 700; }
      .links { display: flex; align-items: center; gap: 22px; }
      .links a:not(.btn) { color: var(--ink); text-decoration: none; font-family: var(--font-sans); }
      .hero { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); align-items: center; max-width: 980px; margin: 0 auto; padding: 6vh 6vw 4vh; }
      .hero-photo { width: 100%; border-radius: 26px; object-fit: cover; aspect-ratio: 4/5; box-shadow: 0 26px 55px #2b3a2a44; }
      .eyebrow { font-family: var(--font-mono); color: var(--clay); letter-spacing: .12em; text-transform: uppercase; font-size: var(--fs-small); margin: 0 0 var(--space-1); }
      h1 { font-size: var(--fs-1); margin: 0 0 var(--space-2); line-height: 1.05; font-weight: 600; }
      .lead { color: #5c5648; font-size: var(--fs-3); line-height: 1.6; max-width: 420px; }
      .cta { display: flex; gap: 14px; margin-top: var(--space-3); flex-wrap: wrap; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: var(--space-3); max-width: 980px; margin: 0 auto; padding: 6vh 6vw; }
      .cards article { background: #fbf7ee; border: 1px solid #e3d8c2; border-radius: 28px; padding: var(--space-3); }
      .emoji { width: 56px; height: 56px; display: grid; place-items: center; font-size: 1.7rem; background: var(--sand); border-radius: 18px; margin-bottom: var(--space-2); }
      h3 { margin: 0 0 var(--space-1); color: var(--accent); } .cards p { margin: 0; color: #5c5648; line-height: 1.6; }
      .band { max-width: 820px; margin: 0 auto; padding: 8vh 6vw; text-align: center; }
      blockquote { font-size: clamp(1.5rem, 4vw, 2.4rem); margin: 0 0 var(--space-3); color: var(--accent); line-height: 1.3; }
      footer { display: flex; justify-content: space-between; align-items: center; max-width: 980px; margin: 0 auto; padding: 5vh 6vw; color: #8a7c68; font-family: var(--font-sans); font-size: var(--fs-small); }
      footer a { color: var(--clay); text-decoration: none; }
      @media (max-width: 720px){ .hero { grid-template-columns: 1fr; } .hero-photo { aspect-ratio: 16/10; order: -1; } .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
