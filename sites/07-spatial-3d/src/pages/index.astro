---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';

const layers = [
  { ic: '◈', t: 'Перспектива', d: 'perspective + preserve-3d создают реальную глубину сцены.' },
  { ic: '▤', t: 'Слои', d: 'translateZ разносит элементы по оси Z — параллакс без скрипта.' },
  { ic: '✦', t: 'Отклик', d: 'Сцена наклоняется за курсором — лёгкий pointer-параллакс.' },
];
const stats = [ { n: '0', l: 'зависимостей' }, { n: '6', l: 'граней' }, { n: '60fps', l: 'плавность' } ];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Пространственный 3D</title>
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">◆ depth</a>
      <div class="links">
        <a href="#how">Как</a><a href="#layers">Слои</a>
        <a href="#" class="btn btn-sm">Демо</a>
      </div>
    </nav>

    <header class="hero">
      <div class="stage" id="stage">
        <div class="cube">
          <span class="face fx">3D</span><span class="face bk">web</span>
          <span class="face rt">↑</span><span class="face lf">→</span>
          <span class="face tp">◆</span><span class="face bm">●</span>
        </div>
      </div>
      <div class="copy">
        <p class="eyebrow m-fade-up">тренд · spatial 3d</p>
        <h1 class="m-fade-up" style="animation-delay:.1s">Глубина без движка</h1>
        <p class="lead m-fade-up" style="animation-delay:.2s">Перспектива, слои и вращение на чистом CSS 3D — ощущение пространства без three.js. Двигай мышью: сцена наклоняется за курсором.</p>
        <div class="row m-fade-up" style="animation-delay:.3s">
          <a class="btn btn-lg" href="#layers">Как это устроено</a>
          <a class="btn btn-lg ghost" href="/">На витрину</a>
        </div>
      </div>
    </header>

    <section id="layers" class="layers">
      {layers.map((l, i) => (
        <article class="layer" style={`--m-i:${i}`}>
          <span class="ic">{l.ic}</span>
          <h3>{l.t}</h3>
          <p>{l.d}</p>
        </article>
      ))}
    </section>

    <section id="how" class="stats">
      {stats.map((s) => (<div><b>{s.n}</b><span>{s.l}</span></div>))}
    </section>

    <footer><span>◆ depth — CSS 3D · 2026</span><a href="/">← на витрину</a></footer>

    <script is:inline>
      const stage = document.getElementById('stage');
      if (stage) window.addEventListener('pointermove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 2;
        const y = (e.clientY / window.innerHeight - 0.5) * 2;
        stage.style.setProperty('--rx', (-y * 12) + 'deg');
        stage.style.setProperty('--ry', (x * 16) + 'deg');
      });
    </script>

    <style>
      :root { --acc: #818cf8; --s: 130px; }
      * { box-sizing: border-box; }
      body { margin: 0; color: #e9e9ff; font-family: var(--font-sans);
        background: radial-gradient(80% 60% at 50% 0%, #2a2a55, #0a0a1a 70%); min-height: 100vh; }
      .btn { display: inline-block; text-decoration: none; color: #0a0612; font-weight: 700; background: var(--acc);
        border-radius: 10px; padding: 11px 22px; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn-sm { padding: 8px 16px; font-size: .9rem; }
      .btn-lg { padding: 14px 26px; }
      .btn.ghost { background: transparent; border: 1px solid #ffffff33; color: #e9e9ff; }
      .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 6vw; }
      .logo { color: #fff; text-decoration: none; font-weight: 800; }
      .links { display: flex; align-items: center; gap: 22px; }
      .links a { color: #b9bce0; text-decoration: none; font-size: .92rem; }

      .hero { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: center;
        max-width: 1040px; margin: 0 auto; padding: 8vh 6vw; }
      .stage { perspective: 900px; display: grid; place-items: center; min-height: 320px;
        transform: rotateX(var(--rx,-12deg)) rotateY(var(--ry,18deg)); transition: transform .12s ease-out; }
      .cube { position: relative; width: var(--s); height: var(--s); transform-style: preserve-3d; animation: spin 14s linear infinite; }
      @keyframes spin { to { transform: rotateX(360deg) rotateY(360deg); } }
      @media (prefers-reduced-motion: reduce){ .cube { animation: none; } }
      .face { position: absolute; inset: 0; display: grid; place-items: center; font-weight: 800; font-size: 1.8rem;
        border: 1px solid #818cf8aa; background: rgba(129,140,248,.14); backdrop-filter: blur(4px); box-shadow: inset 0 0 30px #818cf855; color: #c7ccff; }
      .fx { transform: translateZ(calc(var(--s)/2)); } .bk { transform: rotateY(180deg) translateZ(calc(var(--s)/2)); }
      .rt { transform: rotateY(90deg) translateZ(calc(var(--s)/2)); } .lf { transform: rotateY(-90deg) translateZ(calc(var(--s)/2)); }
      .tp { transform: rotateX(90deg) translateZ(calc(var(--s)/2)); } .bm { transform: rotateX(-90deg) translateZ(calc(var(--s)/2)); }
      .eyebrow { font-family: var(--font-mono); color: var(--acc); letter-spacing: .12em; text-transform: uppercase; font-size: var(--fs-small); margin: 0 0 var(--space-1); }
      h1 { font-size: var(--fs-1); margin: 0 0 var(--space-2); }
      .lead { color: #b9bce0; font-size: var(--fs-3); line-height: 1.6; max-width: 440px; }
      .row { display: flex; gap: 14px; margin-top: var(--space-3); flex-wrap: wrap; }

      .layers { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 18px;
        max-width: 1040px; margin: 0 auto; padding: 4vh 6vw; }
      .layer { background: rgba(129,140,248,.08); border: 1px solid #ffffff1a; border-radius: 18px; padding: 24px;
        animation: m-fade-up .7s var(--ease) both; animation-delay: calc(var(--m-i) * .1s); transition: transform .2s; }
      .layer:hover { transform: translateY(-5px); border-color: var(--acc); }
      .ic { font-size: 1.8rem; color: var(--acc); }
      .layer h3 { margin: 10px 0 6px; font-size: 1.25rem; }
      .layer p { margin: 0; color: #b9bce0; line-height: 1.55; }
      .stats { display: flex; justify-content: center; gap: 56px; flex-wrap: wrap; max-width: 1040px; margin: 0 auto; padding: 6vh 6vw; }
      .stats div { text-align: center; } .stats b { display: block; font-size: 2.2rem; font-weight: 800; }
      .stats span { color: #9b90bd; font-size: .85rem; }
      footer { display: flex; justify-content: space-between; align-items: center; max-width: 1040px; margin: 0 auto; padding: 4vh 6vw; color: #9b90bd; }
      footer a { color: var(--acc); text-decoration: none; }
      @media (max-width: 760px){ .hero { grid-template-columns: 1fr; text-align: center; } .lead { margin: 0 auto; } .row { justify-content: center; } .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
