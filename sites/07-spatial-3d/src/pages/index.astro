---
const base = import.meta.env.BASE_URL;
const product = `${base}img/headphones.webp`;
const specs = [
  { n: '40ч', l: 'автономность' },
  { n: '−42дБ', l: 'шумоподавление' },
  { n: '0.05с', l: 'задержка звука' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Orbit One — звук вокруг тебя</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">◯ Orbit</a>
      <div class="links">
        <a href="#specs">Характеристики</a>
        <a href="#" class="btn">Купить · 24 990 ₽</a>
      </div>
    </nav>

    <header class="hero">
      <div class="copy">
        <span class="eyebrow">orbit one · 2026</span>
        <h1>Звук, который<br>обтекает тебя</h1>
        <p class="lead">Пространственное аудио с динамическим шумоподавлением. 40 часов музыки и тишины — по запросу.</p>
        <div class="cta">
          <a href="#" class="btn lg">Купить · 24 990 ₽</a>
          <a href="#specs" class="btn lg ghost">Характеристики</a>
        </div>
      </div>
      <div class="stage" id="stage">
        <div class="halo"></div>
        <img class="product m-float" src={product} alt="Наушники Orbit One" loading="eager" />
      </div>
    </header>

    <section id="specs" class="specs">
      {specs.map((s) => (<div><b>{s.n}</b><span>{s.l}</span></div>))}
    </section>

    <section class="cta-band">
      <h2>Надень тишину</h2>
      <a href="#" class="btn lg">Заказать Orbit One</a>
    </section>

    <footer class="foot"><span>◯ Orbit · 2026</span><a href="/">← на витрину</a></footer>

    <script is:inline>
      const st = document.getElementById('stage');
      if (st) window.addEventListener('pointermove', (e) => {
        const x = (e.clientX / window.innerWidth - .5) * 2;
        const y = (e.clientY / window.innerHeight - .5) * 2;
        st.style.setProperty('--rx', (-y * 10) + 'deg');
        st.style.setProperty('--ry', (x * 14) + 'deg');
      });
    </script>

    <style>
      :root { --bg:#0c0a1a; --text:#f1efff; --dim:#aaa3d0; --acc:#a78bfa; --acc2:#6ea8ff; --font:'Space Grotesk', system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; min-height: 100vh; color: var(--text); font-family: var(--font);
        background: radial-gradient(90% 70% at 70% 10%, #2a2566, #0c0a1a 70%); }
      .m-float { animation: float 5s ease-in-out infinite; }
      @keyframes float { 50% { transform: translateY(-14px); } }
      @media (prefers-reduced-motion: reduce){ .m-float { animation: none; } }
      .btn { display: inline-block; text-decoration: none; font-weight: 600; color: #0c0a1a; background: #fff; border-radius: 12px; padding: 11px 20px; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn.lg { padding: 15px 28px; font-size: 1.05rem; }
      .btn.ghost { background: rgba(255,255,255,.1); color: #fff; border: 1px solid rgba(255,255,255,.3); }
      .nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 6vw; position: relative; z-index: 3; }
      .logo { color: #fff; text-decoration: none; font-weight: 700; font-size: 1.3rem; }
      .links { display: flex; align-items: center; gap: 22px; } .links a:not(.btn) { color: var(--dim); text-decoration: none; }
      .hero { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; max-width: 1180px; margin: 0 auto; padding: 6vh 6vw; }
      .eyebrow { color: var(--acc); font-weight: 600; font-size: .8rem; letter-spacing: .2em; text-transform: uppercase; }
      h1 { font-size: clamp(2.6rem, 6vw, 4.4rem); font-weight: 600; line-height: 1.04; margin: 16px 0; letter-spacing: -.02em; }
      .lead { color: var(--dim); font-size: 1.2rem; line-height: 1.6; max-width: 420px; margin: 0 0 30px; }
      .cta { display: flex; gap: 14px; flex-wrap: wrap; }
      .stage { position: relative; display: grid; place-items: center; min-height: 380px; perspective: 900px; }
      .stage { transform: rotateX(var(--rx,-6deg)) rotateY(var(--ry,10deg)); transition: transform .12s ease-out; }
      .halo { position: absolute; width: 320px; height: 320px; border-radius: 50%; background: radial-gradient(circle, rgba(167,139,250,.5), transparent 65%); filter: blur(30px); }
      .product { position: relative; width: 80%; max-width: 420px; filter: drop-shadow(0 30px 50px rgba(0,0,0,.5)); }
      .specs { display: flex; justify-content: center; gap: 60px; flex-wrap: wrap; max-width: 900px; margin: 0 auto; padding: 4vh 6vw 8vh; }
      .specs div { text-align: center; } .specs b { display: block; font-size: 2.4rem; font-weight: 600; color: var(--acc2); } .specs span { color: var(--dim); font-size: .9rem; }
      .cta-band { text-align: center; padding: 2vh 6vw 10vh; } .cta-band h2 { font-size: clamp(1.8rem,5vw,2.8rem); font-weight: 600; margin: 0 0 26px; }
      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1180px; margin: 0 auto; padding: 4vh 6vw; color: var(--dim); font-size: .9rem; border-top: 1px solid rgba(255,255,255,.1); }
      .foot a { color: var(--acc); text-decoration: none; }
      @media (max-width: 760px){ .hero { grid-template-columns: 1fr; text-align: center; } .lead { margin: 0 auto 30px; } .cta { justify-content: center; } .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
