---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Пространственный 3D</title>
  </head>
  <body>
    <main>
      <div class="stage">
        <div class="cube">
          <span class="face fx">3D</span>
          <span class="face bk">web</span>
          <span class="face rt">↑</span>
          <span class="face lf">→</span>
          <span class="face tp">◆</span>
          <span class="face bm">●</span>
        </div>
      </div>

      <section class="copy">
        <p class="eyebrow m-fade-up">тренд · spatial 3d</p>
        <h1 class="m-fade-up" style="animation-delay:.1s">Глубина без движка</h1>
        <p class="lead m-fade-up" style="animation-delay:.2s">
          Перспектива, слои и вращение на чистом CSS 3D — ощущение пространства без three.js и тяжёлых зависимостей.
          Двигай мышью: сцена наклоняется за курсором.
        </p>
        <a class="back" href="/">← на витрину</a>
      </section>
    </main>

    <script is:inline>
      const stage = document.querySelector('.stage');
      window.addEventListener('pointermove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 2;
        const y = (e.clientY / window.innerHeight - 0.5) * 2;
        stage.style.setProperty('--rx', (-y * 12) + 'deg');
        stage.style.setProperty('--ry', (x * 16) + 'deg');
      });
    </script>

    <style>
      :root { --accent: #818cf8; --s: 130px; }
      * { box-sizing: border-box; }
      body { margin: 0; min-height: 100vh; color: #e9e9ff; font-family: var(--font-sans);
        background: radial-gradient(80% 60% at 50% 10%, #2a2a55, #0a0a1a 70%);
        display: grid; place-items: center; overflow: hidden; }
      main { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: center;
        max-width: 980px; padding: var(--space-3); }
      .stage { perspective: 900px; display: grid; place-items: center; min-height: 360px;
        transform: rotateX(var(--rx,-12deg)) rotateY(var(--ry,18deg)); transition: transform .12s ease-out; }
      .cube { position: relative; width: var(--s); height: var(--s); transform-style: preserve-3d;
        animation: spin 14s linear infinite; }
      @keyframes spin { to { transform: rotateX(360deg) rotateY(360deg); } }
      @media (prefers-reduced-motion: reduce){ .cube { animation: none; } }
      .face { position: absolute; inset: 0; display: grid; place-items: center; font-weight: 800; font-size: 1.8rem;
        border: 1px solid #818cf8aa; background: rgba(129,140,248,.14); backdrop-filter: blur(4px);
        box-shadow: inset 0 0 30px #818cf855; color: #c7ccff; }
      .fx { transform: translateZ(calc(var(--s)/2)); }
      .bk { transform: rotateY(180deg) translateZ(calc(var(--s)/2)); }
      .rt { transform: rotateY(90deg) translateZ(calc(var(--s)/2)); }
      .lf { transform: rotateY(-90deg) translateZ(calc(var(--s)/2)); }
      .tp { transform: rotateX(90deg) translateZ(calc(var(--s)/2)); }
      .bm { transform: rotateX(-90deg) translateZ(calc(var(--s)/2)); }
      .eyebrow { font-family: var(--font-mono); color: var(--accent); letter-spacing: .12em; text-transform: uppercase; font-size: var(--fs-small); margin: 0 0 var(--space-1); }
      h1 { font-size: var(--fs-1); margin: 0 0 var(--space-2); }
      .lead { color: #b9bce0; font-size: var(--fs-3); line-height: 1.6; max-width: 440px; }
      .back { display: inline-block; margin-top: var(--space-3); color: var(--accent); text-decoration: none; font-family: var(--font-mono); }
      @media (max-width: 760px){ main { grid-template-columns: 1fr; text-align: center; } .lead { margin: 0 auto; } }
    </style>
  </body>
</html>
