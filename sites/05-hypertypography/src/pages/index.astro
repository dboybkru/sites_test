---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';

const principles = [
  { n: '01', t: 'МАСШТАБ', d: 'Размер кегля задаёт иерархию быстрее любого цвета.' },
  { n: '02', t: 'КОНТРАСТ', d: 'Тонкое рядом с жирным. Узкое рядом с широким.' },
  { n: '03', t: 'РИТМ', d: 'Повтор и пауза. Текст дышит за счёт воздуха.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Гипертипографика</title>
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">TYPE/SET</a>
      <div class="links">
        <a href="#principles">Принципы</a>
        <a href="#" class="btn">Заказать</a>
      </div>
    </nav>

    <main class="hero">
      <p class="meta m-fade-up">тренд · hyper-type · 2026</p>
      <h1 class="mega">
        <span class="line m-fade-up" style="animation-delay:.05s">ШРИФТ —</span>
        <span class="line outline m-fade-up" style="animation-delay:.15s">ЭТО</span>
        <span class="line accent m-fade-up" style="animation-delay:.25s">ИНТЕРФЕЙС</span>
      </h1>
      <p class="dek m-fade-up" style="animation-delay:.4s">Когда типографика становится главным героем: масштаб, контраст начертаний и ритм несут смысл сильнее иллюстраций.</p>
      <div class="cta m-fade-up" style="animation-delay:.5s">
        <a class="btn btn-lg" href="#principles">Смотреть принципы</a>
        <a class="link" href="/">← на витрину</a>
      </div>
    </main>

    <div class="marquee"><div class="track">
      <span>ДИСПЛЕЙ&nbsp;·&nbsp;КОНТРАСТ&nbsp;·&nbsp;КЕГЛЬ&nbsp;·&nbsp;РИТМ&nbsp;·&nbsp;ВОЗДУХ&nbsp;·&nbsp;</span>
      <span>ДИСПЛЕЙ&nbsp;·&nbsp;КОНТРАСТ&nbsp;·&nbsp;КЕГЛЬ&nbsp;·&nbsp;РИТМ&nbsp;·&nbsp;ВОЗДУХ&nbsp;·&nbsp;</span>
    </div></div>

    <section id="principles" class="principles">
      {principles.map((p) => (
        <article class="pr">
          <span class="pn">{p.n}</span>
          <h2>{p.t}</h2>
          <p>{p.d}</p>
        </article>
      ))}
    </section>

    <section class="quote">
      <blockquote>«Хорошая типографика&nbsp;— это <em>интерфейс</em>, которого&nbsp;не&nbsp;замечаешь.»</blockquote>
    </section>

    <footer>
      <span class="big">ГОТОВ НАБРАТЬ ГРОМКО?</span>
      <a class="btn btn-lg" href="#">Начать проект</a>
    </footer>

    <style>
      :root { --accent: #facc15; --ink: #0c0c0c; --paper: #f4f2ec; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--font-sans); overflow-x: hidden; }
      .btn { display: inline-block; background: var(--ink); color: var(--paper); text-decoration: none; font-weight: 800;
        padding: 12px 24px; border: 3px solid var(--ink); transition: background .15s, color .15s; }
      .btn:hover { background: var(--accent); color: var(--ink); }
      .btn-lg { padding: 16px 34px; font-size: 1.1rem; }
      .link { color: var(--ink); text-decoration: none; font-family: var(--font-mono); align-self: center; }
      .nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 5vw; border-bottom: 3px solid var(--ink); }
      .logo { font-weight: 900; font-family: var(--font-mono); letter-spacing: -.02em; color: var(--ink); text-decoration: none; font-size: 1.2rem; }
      .links { display: flex; align-items: center; gap: 22px; }
      .links a:not(.btn) { color: var(--ink); text-decoration: none; font-family: var(--font-mono); }
      .hero { max-width: 1100px; margin: 0 auto; padding: 8vh 5vw 6vh; }
      .meta { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .3em; font-size: var(--fs-small); margin: 0 0 var(--space-3); }
      .mega { margin: 0; line-height: .86; font-weight: 900; letter-spacing: -.03em; text-transform: uppercase; }
      .line { display: block; font-size: clamp(3rem, 16vw, 11rem); }
      .outline { color: transparent; -webkit-text-stroke: 2px var(--ink); }
      .accent { color: var(--accent); -webkit-text-stroke: 2px var(--ink); }
      .dek { max-width: 540px; margin: var(--space-4) 0 0 auto; font-size: var(--fs-3); line-height: 1.5; text-align: right; }
      .cta { display: flex; gap: 22px; justify-content: flex-end; margin-top: var(--space-3); flex-wrap: wrap; }
      .marquee { border-top: 3px solid var(--ink); border-bottom: 3px solid var(--ink); overflow: hidden; background: var(--accent); }
      .track { display: inline-flex; white-space: nowrap; animation: scroll 18s linear infinite; }
      .track span { font-weight: 900; font-size: clamp(1.4rem, 4vw, 2.6rem); padding: 10px 0; text-transform: uppercase; }
      @keyframes scroll { to { transform: translateX(-50%); } }
      @media (prefers-reduced-motion: reduce){ .track { animation: none; } }
      .principles { max-width: 1100px; margin: 0 auto; padding: 9vh 5vw; display: grid; gap: 0; }
      .pr { display: grid; grid-template-columns: auto 1fr; gap: 28px; align-items: baseline; padding: 36px 0; border-bottom: 3px solid var(--ink); }
      .pn { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 700; }
      .pr h2 { font-size: clamp(2.4rem, 8vw, 5rem); margin: 0; font-weight: 900; letter-spacing: -.02em; line-height: 1; }
      .pr p { grid-column: 2; margin: 14px 0 0; font-size: var(--fs-3); max-width: 480px; }
      .quote { padding: 10vh 5vw; background: var(--ink); color: var(--paper); }
      blockquote { max-width: 900px; margin: 0 auto; font-size: clamp(1.6rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.15; letter-spacing: -.01em; }
      blockquote em { color: var(--accent); font-style: normal; }
      footer { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; padding: 7vh 5vw; }
      footer .big { font-size: clamp(1.4rem, 5vw, 2.6rem); font-weight: 900; text-transform: uppercase; letter-spacing: -.02em; max-width: 640px; }
      @media (max-width: 640px){ .dek, .cta { text-align: left; margin-left: 0; justify-content: flex-start; } .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
