---
const base = import.meta.env.BASE_URL;
const day = `${base}img/day.webp`;
const night = `${base}img/night.webp`;
const facts = [
  { n: '1962', l: 'год постройки' },
  { n: '4', l: 'уровня в склоне' },
  { n: '∞', l: 'джунгли вокруг' },
];
const amenities = [
  { t: 'Бетон и зелень', d: 'Сырой бетон, который десятилетиями обрастал лианами и мхом — архитектура, ставшая ландшафтом.' },
  { t: 'Открытые террасы', d: 'Каждый уровень выходит к воде. Граница между домом и лесом стёрта.' },
  { t: 'Свет вечером', d: 'С наступлением темноты дом светится тёплыми окнами сквозь листву.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Concrete & Canopy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">C&nbsp;/&nbsp;C</a>
      <div class="links">
        <a href="#about">О доме</a>
        <a href="#gallery">Галерея</a>
        <a href="#" class="btn">Забронировать</a>
      </div>
    </nav>

    <header class="hero" style={`background-image: linear-gradient(180deg, rgba(8,10,8,.45), rgba(8,10,8,.25) 40%, rgba(8,10,8,.85)), url(${night})`}>
      <div class="hero-inner">
        <p class="eyebrow">архитектурный ретрит · бразилия</p>
        <h1>Concrete<br>&amp; Canopy</h1>
        <p class="sub">Бруталистская вилла, которую за полвека поглотили джунгли. Бетон, вода и тропический лес — в одном дыхании.</p>
        <div class="cta">
          <a href="#about" class="btn solid">Узнать историю</a>
          <a href="#gallery" class="btn line">Смотреть фото ↓</a>
        </div>
      </div>
      <div class="facts">
        {facts.map((f) => (<div><b>{f.n}</b><span>{f.l}</span></div>))}
      </div>
    </header>

    <section id="about" class="about">
      <div class="about-text">
        <p class="kicker">о доме</p>
        <h2>Там, где бетон уступает лесу</h2>
        {amenities.map((a) => (
          <div class="amenity"><h3>{a.t}</h3><p>{a.d}</p></div>
        ))}
        <a href="#" class="btn solid">Запросить тур</a>
      </div>
      <figure class="about-photo">
        <img src={day} alt="Бруталистская вилла в джунглях днём" loading="lazy" />
      </figure>
    </section>

    <section id="gallery" class="gallery">
      <figure class="g-night"><img src={night} alt="Вилла вечером" loading="lazy" /><figcaption>Сумерки</figcaption></figure>
      <figure class="g-day"><img src={day} alt="Вилла днём" loading="lazy" /><figcaption>Полдень</figcaption></figure>
    </section>

    <footer class="foot">
      <span>Concrete &amp; Canopy · фото-демо · 2026</span>
      <a href="/">← на витрину</a>
    </footer>

    <style>
      :root { --bg:#0a0c0a; --text:#f2f0e9; --dim:#b7bdb0; --accent:#a3b18a; --line:#252a24;
        --serif:'Cormorant Garamond', Georgia, serif; --sans:'Inter', system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--text); font-family: var(--sans); }
      .btn { text-decoration: none; font-weight: 500; font-size: 15px; padding: 13px 26px; border-radius: 4px; transition: transform .15s, background .2s; display: inline-block; }
      .btn:hover { transform: translateY(-2px); }
      .btn.solid, .links .btn { background: var(--accent); color: #11160f; }
      .btn.line { color: #fff; border: 1px solid rgba(255,255,255,.4); }

      .nav { position: absolute; top: 0; left: 0; right: 0; z-index: 3; display: flex; align-items: center; justify-content: space-between; padding: 24px 6vw; }
      .logo { color: #fff; text-decoration: none; font-family: var(--serif); font-size: 26px; font-weight: 600; letter-spacing: .04em; }
      .links { display: flex; align-items: center; gap: 26px; }
      .links a:not(.btn) { color: #e8e8e0; text-decoration: none; font-size: 15px; }

      .hero { position: relative; min-height: 100vh; background-size: cover; background-position: center;
        display: flex; flex-direction: column; justify-content: center; padding: 0 6vw; }
      .hero-inner { max-width: 640px; }
      .eyebrow { color: var(--accent); font-size: 13px; letter-spacing: .25em; text-transform: uppercase; margin: 0 0 16px; }
      h1 { font-family: var(--serif); font-weight: 600; font-size: clamp(3.4rem, 10vw, 7rem); line-height: .98; margin: 0 0 22px; letter-spacing: .01em; }
      .sub { color: var(--dim); font-size: 19px; line-height: 1.6; max-width: 460px; margin: 0 0 32px; }
      .cta { display: flex; gap: 14px; flex-wrap: wrap; }
      .facts { display: flex; gap: 56px; position: absolute; bottom: 48px; left: 6vw; }
      .facts div { display: flex; flex-direction: column; }
      .facts b { font-family: var(--serif); font-size: 2.4rem; line-height: 1; }
      .facts span { color: var(--dim); font-size: .8rem; letter-spacing: .08em; text-transform: uppercase; margin-top: 6px; }

      .about { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; max-width: 1200px; margin: 0 auto; padding: 14vh 6vw; }
      .kicker { color: var(--accent); font-size: 13px; letter-spacing: .2em; text-transform: uppercase; margin: 0 0 12px; }
      .about h2 { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 600; margin: 0 0 32px; line-height: 1.1; }
      .amenity { padding: 20px 0; border-top: 1px solid var(--line); }
      .amenity h3 { margin: 0 0 6px; font-size: 1.1rem; font-weight: 500; }
      .amenity p { margin: 0; color: var(--dim); line-height: 1.6; }
      .about-text .btn { margin-top: 28px; }
      .about-photo { margin: 0; }
      .about-photo img { width: 100%; border-radius: 8px; display: block; box-shadow: 0 30px 60px rgba(0,0,0,.5); }

      .gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 1400px; margin: 0 auto; padding: 0 4vw 12vh; }
      .gallery figure { margin: 0; position: relative; overflow: hidden; border-radius: 8px; }
      .gallery img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 16/11; transition: transform .6s ease; }
      .gallery figure:hover img { transform: scale(1.04); }
      .gallery figcaption { position: absolute; left: 18px; bottom: 16px; color: #fff; font-family: var(--serif); font-size: 1.4rem; text-shadow: 0 2px 12px rgba(0,0,0,.6); }

      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 5vh 6vw; color: var(--dim); font-size: 14px; border-top: 1px solid var(--line); }
      .foot a { color: var(--accent); text-decoration: none; }

      @media (max-width: 820px){
        .links a:not(.btn) { display: none; }
        .about { grid-template-columns: 1fr; gap: 32px; }
        .gallery { grid-template-columns: 1fr; }
        .facts { gap: 32px; position: static; margin-top: 40px; }
      }
    </style>
  </body>
</html>
