---
const base = import.meta.env.BASE_URL;
const sky = `${base}img/sky.webp`;
const hours = [
  { t: '15:00', i: '☀️', d: '24°' },
  { t: '16:00', i: '🌤️', d: '24°' },
  { t: '17:00', i: '⛅', d: '23°' },
  { t: '18:00', i: '🌥️', d: '21°' },
  { t: '19:00', i: '🌇', d: '19°' },
];
const week = [
  { d: 'Пн', i: '☀️', hi: '25°', lo: '17°' },
  { d: 'Вт', i: '⛅', hi: '24°', lo: '16°' },
  { d: 'Ср', i: '🌧️', hi: '20°', lo: '15°' },
  { d: 'Чт', i: '🌤️', hi: '23°', lo: '16°' },
];
const features = [
  { ic: '🛰️', t: 'Точность по минутам', d: 'Гиперлокальный прогноз осадков на час вперёд — до начала дождя.' },
  { ic: '🌅', t: 'Живые фоны', d: 'Интерфейс меняет настроение вместе с небом за окном.' },
  { ic: '🔔', t: 'Тихие уведомления', d: 'Предупредим о грозе или гололёде — и ни о чём лишнем.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Aura — погода, на которую приятно смотреть</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body style={`background-image: url(${sky})`}>
    <div class="veil"></div>

    <nav class="nav glass">
      <a class="logo" href="#">◐ Aura</a>
      <div class="nav-right">
        <a href="#features">Возможности</a>
        <a href="#forecast">Прогноз</a>
        <a href="#" class="btn">Скачать</a>
      </div>
    </nav>

    <header class="hero">
      <div class="hero-copy">
        <span class="eyebrow glass">● погода нового поколения</span>
        <h1>Погода, на которую<br>приятно смотреть</h1>
        <p class="lead">Aura показывает небо таким, какое оно есть прямо сейчас. Гиперлокальный прогноз в интерфейсе, который дышит вместе с городом.</p>
        <div class="cta">
          <a href="#" class="btn lg">App Store</a>
          <a href="#" class="btn lg ghost">Google Play</a>
        </div>
        <p class="rating glass">★ 4.9 · 38&nbsp;000 оценок</p>
      </div>

      <aside class="widget glass">
        <div class="w-top">
          <div><p class="w-city">Сочи</p><p class="w-cond">Ясно, к вечеру облачно</p></div>
          <p class="w-temp">+24°</p>
        </div>
        <div class="w-meta">
          <span>Ощущается 26°</span><span>Ветер 3 м/с</span><span>Влажность 60%</span>
        </div>
        <div class="w-hours">
          {hours.map((h) => (
            <div class="h"><span>{h.t}</span><span class="hi">{h.i}</span><b>{h.d}</b></div>
          ))}
        </div>
      </aside>
    </header>

    <section id="forecast" class="forecast">
      {week.map((w) => (
        <article class="day glass">
          <span class="dn">{w.d}</span>
          <span class="di">{w.i}</span>
          <span class="dt"><b>{w.hi}</b> / {w.lo}</span>
        </article>
      ))}
    </section>

    <section id="features" class="features">
      {features.map((f) => (
        <article class="feat glass">
          <span class="fi">{f.ic}</span>
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </section>

    <footer class="foot glass">
      <span>◐ Aura · погода · 2026</span>
      <a href="/">← на витрину</a>
    </footer>

    <style>
      :root { --accent: #ff8fb1; --font: 'Manrope', system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; min-height: 100vh; color: #fff; font-family: var(--font);
        background-size: cover; background-position: center; background-attachment: fixed; }
      .veil { position: fixed; inset: 0; z-index: 0; background: linear-gradient(180deg, rgba(40,20,55,.25), rgba(30,12,45,.55)); }
      nav, header, section, footer { position: relative; z-index: 1; }
      .glass { background: rgba(255,255,255,.14); backdrop-filter: blur(22px) saturate(160%); -webkit-backdrop-filter: blur(22px) saturate(160%);
        border: 1px solid rgba(255,255,255,.28); box-shadow: 0 10px 40px rgba(40,15,55,.28), inset 0 1px 0 rgba(255,255,255,.4); }
      .btn { display: inline-block; text-decoration: none; font-weight: 700; color: #3a1230; background: #fff; border-radius: 999px; padding: 11px 22px; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn.lg { padding: 14px 28px; }
      .btn.ghost { background: rgba(255,255,255,.16); color: #fff; border: 1px solid rgba(255,255,255,.4); }

      .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; margin: 18px 4vw; border-radius: 18px; }
      .logo { font-weight: 800; font-size: 1.3rem; color: #fff; text-decoration: none; }
      .nav-right { display: flex; align-items: center; gap: 22px; }
      .nav-right a:not(.btn) { color: rgba(255,255,255,.9); text-decoration: none; font-weight: 500; }
      .nav-right a.btn { color: #3a1230; }

      .hero { display: grid; grid-template-columns: 1.1fr .9fr; gap: 48px; align-items: center; max-width: 1180px; margin: 0 auto; padding: 6vh 6vw 8vh; }
      .eyebrow { display: inline-block; border-radius: 999px; padding: 7px 16px; font-size: .82rem; font-weight: 600; margin-bottom: 22px; }
      h1 { font-size: clamp(2.4rem, 5.2vw, 4rem); font-weight: 800; line-height: 1.05; margin: 0 0 18px; letter-spacing: -.02em; text-shadow: 0 2px 30px rgba(40,10,50,.4); }
      .lead { font-size: 1.15rem; line-height: 1.6; color: rgba(255,255,255,.92); max-width: 460px; margin: 0 0 28px; }
      .cta { display: flex; gap: 14px; flex-wrap: wrap; }
      .rating { display: inline-block; margin-top: 22px; padding: 8px 16px; border-radius: 999px; font-size: .85rem; font-weight: 600; }

      .widget { border-radius: 26px; padding: 26px; }
      .w-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
      .w-city { font-size: 1.5rem; font-weight: 700; margin: 0; }
      .w-cond { margin: 4px 0 0; color: rgba(255,255,255,.85); font-size: .9rem; }
      .w-temp { font-size: 3.6rem; font-weight: 800; margin: 0; line-height: .9; letter-spacing: -.03em; }
      .w-meta { display: flex; gap: 16px; flex-wrap: wrap; margin: 18px 0; font-size: .82rem; color: rgba(255,255,255,.85); }
      .w-hours { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
      .h { display: flex; flex-direction: column; align-items: center; gap: 7px; padding: 12px 6px; border-radius: 14px; background: rgba(255,255,255,.12); font-size: .8rem; }
      .h .hi { font-size: 1.2rem; } .h b { font-size: .95rem; }

      .forecast { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; max-width: 1180px; margin: 0 auto; padding: 0 6vw 8vh; }
      .day { border-radius: 18px; padding: 18px; display: flex; align-items: center; justify-content: space-between; }
      .dn { font-weight: 700; } .di { font-size: 1.4rem; } .dt { color: rgba(255,255,255,.85); font-size: .95rem; } .dt b { color: #fff; }

      .features { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 16px; max-width: 1180px; margin: 0 auto; padding: 0 6vw 8vh; }
      .feat { border-radius: 22px; padding: 26px; }
      .fi { font-size: 1.8rem; } .feat h3 { margin: 12px 0 8px; font-size: 1.2rem; } .feat p { margin: 0; color: rgba(255,255,255,.88); line-height: 1.55; }

      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1180px; margin: 0 auto 4vh; padding: 18px 26px; border-radius: 16px; color: rgba(255,255,255,.9); font-size: .9rem; }
      .foot a { color: #fff; text-decoration: none; font-weight: 600; }

      @media (max-width: 820px){
        .hero { grid-template-columns: 1fr; }
        .forecast { grid-template-columns: repeat(2,1fr); }
        .nav-right a:not(.btn){ display: none; }
      }
    </style>
  </body>
</html>
