---
const base = import.meta.env.BASE_URL;
const chart = `${base}img/chart.webp`;
const cats = [
  { t: 'Кафе', v: 38 }, { t: 'Транспорт', v: 22 }, { t: 'Подписки', v: 18 }, { t: 'Прочее', v: 12 },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Stack — деньги под контролем</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#">▦ Stack</a>
      <div class="links">
        <a href="#">Карты</a><a href="#">Тарифы</a>
        <a href="#" class="btn">Открыть счёт</a>
      </div>
    </nav>

    <header class="head">
      <span class="eyebrow">необанк для своих денег</span>
      <h1>Все финансы — на одном экране</h1>
      <p class="lead">Stack собирает счета, карты и накопления в спокойный дашборд. Видно всё, тревожно — нет.</p>
    </header>

    <section class="bento">
      <article class="tile balance">
        <div class="b-top"><span class="kicker">Общий баланс</span><span class="pos">▲ 12.4%</span></div>
        <p class="amount">₽ 1 248 320</p>
        <img class="chart" src={chart} alt="Динамика баланса" loading="lazy" />
      </article>

      <article class="tile glowy">
        <span class="kicker">Кэшбэк за месяц</span>
        <p class="big">₽ 8 410</p>
        <span class="sub">42 операции</span>
      </article>

      <article class="tile card">
        <span class="kicker">Карта</span>
        <p class="cardno">•••• 4921</p>
        <span class="sub">Stack Black</span>
      </article>

      <article class="tile">
        <span class="kicker">Накопления</span>
        <div class="ring" style="--p:67"><b>67%</b></div>
        <span class="sub">цель: квартира</span>
      </article>

      <article class="tile cats">
        <span class="kicker">Куда уходят деньги</span>
        <div class="bars">
          {cats.map((c) => (
            <div class="bar"><span>{c.t}</span><i style={`--v:${c.v}%`}></i><b>{c.v}%</b></div>
          ))}
        </div>
      </article>

      <article class="tile cta">
        <p>Открой счёт за 5 минут</p>
        <a href="#" class="btn">Поехали →</a>
      </article>
    </section>

    <footer class="foot"><span>▦ Stack · 2026</span><a href="/">← на витрину</a></footer>

    <style>
      :root { --bg:#0a0c18; --panel:#12152a; --line:#222644; --text:#eef0ff; --dim:#9aa0c4; --violet:#a78bfa; --teal:#5eead4; --font:'Inter', system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--text); font-family: var(--font); }
      .btn { display: inline-block; text-decoration: none; font-weight: 700; color: #0a0c18; background: var(--teal); border-radius: 12px; padding: 11px 22px; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 6vw; }
      .logo { color: #fff; text-decoration: none; font-weight: 800; }
      .links { display: flex; align-items: center; gap: 22px; }
      .links a:not(.btn) { color: var(--dim); text-decoration: none; }
      .head { max-width: 1100px; margin: 0 auto; padding: 6vh 6vw 3vh; }
      .eyebrow { color: var(--violet); font-weight: 600; font-size: .8rem; letter-spacing: .14em; text-transform: uppercase; }
      h1 { font-size: clamp(2.2rem, 5vw, 3.6rem); font-weight: 800; line-height: 1.05; margin: 14px 0; letter-spacing: -.02em; }
      .lead { color: var(--dim); font-size: 1.15rem; max-width: 480px; margin: 0; }
      .bento { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 150px; gap: 16px; max-width: 1100px; margin: 0 auto; padding: 4vh 6vw 6vh; }
      .tile { background: var(--panel); border: 1px solid var(--line); border-radius: 20px; padding: 22px; display: flex; flex-direction: column; overflow: hidden; }
      .kicker { font-size: .75rem; text-transform: uppercase; letter-spacing: .08em; color: var(--dim); }
      .sub { color: var(--dim); font-size: .82rem; margin-top: auto; }
      .balance { grid-column: span 2; grid-row: span 2; background: linear-gradient(160deg, #1a1740, #12152a); }
      .b-top { display: flex; justify-content: space-between; align-items: center; }
      .pos { color: var(--teal); font-weight: 700; font-size: .85rem; }
      .amount { font-size: clamp(1.8rem,4vw,2.8rem); font-weight: 800; margin: 10px 0 0; letter-spacing: -.02em; }
      .chart { margin-top: auto; width: 100%; border-radius: 12px; opacity: .95; }
      .glowy { grid-column: span 2; background: linear-gradient(135deg, rgba(167,139,250,.22), var(--panel)); }
      .big { font-size: 2.2rem; font-weight: 800; margin: 8px 0; }
      .cardno { font-size: 1.4rem; font-weight: 700; letter-spacing: .1em; margin: 8px 0; font-family: ui-monospace, monospace; }
      .card { background: linear-gradient(135deg, #2a2350, #14162c); }
      .ring { width: 70px; height: 70px; border-radius: 50%; margin: 10px 0 auto; display: grid; place-items: center;
        background: conic-gradient(var(--teal) calc(var(--p) * 1%), #2a2f52 0); }
      .ring b { width: 54px; height: 54px; border-radius: 50%; background: var(--panel); display: grid; place-items: center; font-size: .9rem; }
      .cats { grid-column: span 2; }
      .bars { display: grid; gap: 10px; margin-top: 14px; }
      .bar { display: grid; grid-template-columns: 90px 1fr 40px; align-items: center; gap: 10px; font-size: .85rem; }
      .bar i { height: 8px; border-radius: 999px; background: linear-gradient(90deg, var(--violet), var(--teal)); width: var(--v); }
      .bar b { color: var(--dim); font-weight: 600; text-align: right; }
      .cta { background: linear-gradient(135deg, var(--violet), #7c5cff); color: #fff; justify-content: space-between; }
      .cta p { margin: 0; font-weight: 700; font-size: 1.1rem; } .cta .btn { align-self: flex-start; background: #fff; color: #1a1030; }
      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1100px; margin: 0 auto; padding: 4vh 6vw; color: var(--dim); font-size: .9rem; border-top: 1px solid var(--line); }
      .foot a { color: var(--teal); text-decoration: none; }
      @media (max-width: 700px){ .bento { grid-template-columns: repeat(2,1fr); } .balance,.glowy,.cats { grid-column: span 2; } .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
