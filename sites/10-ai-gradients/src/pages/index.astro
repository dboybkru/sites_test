---
const base = import.meta.env.BASE_URL;
const nebula = `${base}img/nebula.webp`;
const logos = ['stellar', 'quantix', 'northwind', 'lumen', 'vega'];
const features = [
  { ic: '✦', t: 'Контекст без границ', d: 'Помнит миллионы токенов диалога и документов — ничего не теряется между сессиями.' },
  { ic: '◈', t: 'Рассуждение вслух', d: 'Показывает ход мысли, а не только ответ. Можно проверить и поправить.' },
  { ic: '⬡', t: 'Свои данные', d: 'Подключается к вашим базам и API. Отвечает по фактам, а не по догадкам.' },
];
const stats = [
  { n: '1M', l: 'токенов контекста' },
  { n: '40мс', l: 'до первого слова' },
  { n: '99.9%', l: 'аптайм' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nebula — интеллект, который видит дальше</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg" style={`background-image: linear-gradient(180deg, rgba(7,6,15,.35), rgba(7,6,15,.8) 70%, #07060f), url(${nebula})`}></div>

    <nav class="nav">
      <a class="logo" href="#">✦ Nebula</a>
      <div class="nav-right">
        <a href="#features">Платформа</a>
        <a href="#">Цены</a>
        <a href="#" class="btn">Запросить доступ</a>
      </div>
    </nav>

    <header class="hero">
      <span class="chip">● приватный бета-доступ открыт</span>
      <h1>Интеллект, который<br>видит дальше</h1>
      <p class="lead">Nebula — это рассуждающая модель с памятью на миллион токенов. Подключите свои данные и получайте ответы по фактам, а не по догадкам.</p>
      <form class="prompt" onsubmit="return false">
        <span class="pmark">✦</span>
        <input type="text" placeholder="Спросите Nebula что угодно…" aria-label="Запрос" />
        <button type="submit">Спросить →</button>
      </form>
      <div class="logos">
        <span>Уже доверяют:</span>
        {logos.map((l) => (<b>{l}</b>))}
      </div>
    </header>

    <section class="stats">
      {stats.map((s) => (<div><b>{s.n}</b><span>{s.l}</span></div>))}
    </section>

    <section id="features" class="features">
      {features.map((f) => (
        <article class="feat">
          <span class="fi">{f.ic}</span>
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </section>

    <section class="cta-band">
      <h2>Готовы подключить свой интеллект?</h2>
      <a href="#" class="btn lg">Запросить ранний доступ</a>
    </section>

    <footer class="foot"><span>✦ Nebula AI · 2026</span><a href="/">← на витрину</a></footer>

    <style>
      :root { --acc: #c4b5fd; --acc2: #67e8f9; --font: 'Space Grotesk', system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; min-height: 100vh; background: #07060f; color: #f3f1ff; font-family: var(--font); overflow-x: hidden; }
      .bg { position: fixed; inset: 0; z-index: 0; background-size: cover; background-position: center; }
      nav, header, section, footer { position: relative; z-index: 1; }
      .btn { display: inline-block; text-decoration: none; font-weight: 600; color: #0a0612; background: #fff; border-radius: 10px; padding: 11px 20px; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn.lg { padding: 15px 30px; font-size: 1.05rem; }

      .nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 6vw; }
      .logo { font-weight: 700; font-size: 1.3rem; color: #fff; text-decoration: none; }
      .nav-right { display: flex; align-items: center; gap: 24px; }
      .nav-right a:not(.btn) { color: rgba(243,241,255,.8); text-decoration: none; }

      .hero { max-width: 820px; margin: 0 auto; padding: 13vh 6vw 8vh; text-align: center; }
      .chip { display: inline-block; font-size: .82rem; color: #e9deff; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2); border-radius: 999px; padding: 7px 16px; backdrop-filter: blur(8px); }
      h1 { font-size: clamp(2.6rem, 7vw, 5rem); font-weight: 600; line-height: 1.04; margin: 22px 0; letter-spacing: -.02em;
        background: linear-gradient(100deg, #fff, #d8c9ff 40%, #a6f0ff); -webkit-background-clip: text; background-clip: text; color: transparent; }
      .lead { font-size: 1.2rem; line-height: 1.6; color: #cfc6e8; max-width: 580px; margin: 0 auto 32px; }
      .prompt { display: flex; align-items: center; gap: 10px; max-width: 560px; margin: 0 auto; padding: 8px 8px 8px 18px;
        background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2); border-radius: 16px; backdrop-filter: blur(14px); }
      .pmark { color: var(--acc2); }
      .prompt input { flex: 1; background: transparent; border: none; outline: none; color: #fff; font-family: var(--font); font-size: 1rem; padding: 10px 0; }
      .prompt input::placeholder { color: rgba(243,241,255,.5); }
      .prompt button { background: linear-gradient(135deg,#a78bfa,#67e8f9); color: #0a0612; border: none; font-weight: 700; font-family: var(--font); padding: 12px 20px; border-radius: 11px; cursor: pointer; }
      .logos { display: flex; align-items: center; justify-content: center; gap: 22px; flex-wrap: wrap; margin-top: 34px; color: rgba(243,241,255,.5); font-size: .9rem; }
      .logos b { color: rgba(243,241,255,.8); font-weight: 600; letter-spacing: .02em; }

      .stats { display: flex; justify-content: center; gap: 64px; flex-wrap: wrap; max-width: 900px; margin: 0 auto; padding: 4vh 6vw 8vh; }
      .stats div { text-align: center; }
      .stats b { display: block; font-size: 2.6rem; font-weight: 600;
        background: linear-gradient(120deg,#c4b5fd,#67e8f9); -webkit-background-clip: text; background-clip: text; color: transparent; }
      .stats span { color: rgba(243,241,255,.6); font-size: .9rem; }

      .features { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 18px; max-width: 1040px; margin: 0 auto; padding: 0 6vw 8vh; }
      .feat { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 20px; padding: 28px; backdrop-filter: blur(10px); transition: transform .2s, border-color .2s; }
      .feat:hover { transform: translateY(-5px); border-color: var(--acc); }
      .fi { font-size: 1.6rem; color: var(--acc2); }
      .feat h3 { margin: 12px 0 8px; font-size: 1.25rem; font-weight: 600; }
      .feat p { margin: 0; color: #cfc6e8; line-height: 1.6; }

      .cta-band { text-align: center; max-width: 760px; margin: 0 auto; padding: 4vh 6vw 10vh; }
      .cta-band h2 { font-size: clamp(1.8rem,5vw,2.8rem); font-weight: 600; margin: 0 0 26px; }

      .foot { display: flex; align-items: center; justify-content: space-between; max-width: 1040px; margin: 0 auto; padding: 4vh 6vw; color: rgba(243,241,255,.55); font-size: .9rem; border-top: 1px solid rgba(255,255,255,.1); }
      .foot a { color: var(--acc2); text-decoration: none; }

      @media (max-width: 640px){ .nav-right a:not(.btn){ display: none; } .prompt button { padding: 12px 14px; } }
    </style>
  </body>
</html>
