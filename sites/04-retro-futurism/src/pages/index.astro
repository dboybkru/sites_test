---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';

const tracks = [
  { n: '01', t: 'Neon Drive', d: 'Бесконечное шоссе в закат' },
  { n: '02', t: 'Chrome Hearts', d: 'Хром, блики и синтезатор' },
  { n: '03', t: 'Grid Runner', d: 'Перспективная сетка до горизонта' },
];
const stats = [
  { n: '1984', l: 'эстетика' },
  { n: '∞', l: 'горизонт' },
  { n: '120', l: 'BPM' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ретро-футуризм</title>
  </head>
  <body>
    <div class="sun" aria-hidden="true"></div>
    <div class="grid-floor" aria-hidden="true"></div>
    <div class="scanlines" aria-hidden="true"></div>

    <nav class="nav">
      <a class="logo" href="#">NEON<span>2099</span></a>
      <div class="links">
        <a href="#tracks">Треки</a>
        <a href="#about">О стиле</a>
        <a href="#" class="btn btn-sm">▶ Слушать</a>
      </div>
    </nav>

    <header class="hero">
      <p class="eyebrow m-fade-up">тренд · retro-future</p>
      <h1 class="chrome m-fade-up">NEON&nbsp;2099</h1>
      <p class="lead m-fade-up">Эстетика 80-х о будущем: закат, бесконечная сетка, хром и неон. Возврат Y2K в современном вебе.</p>
      <div class="row m-fade-up">
        <a class="btn btn-lg" href="#">▶ Запуск</a>
        <a class="btn btn-lg btn-ghost" href="#tracks">Треклист</a>
      </div>
    </header>

    <section id="tracks" class="panel">
      <h2>Треклист</h2>
      <div class="tracks">
        {tracks.map((tr) => (
          <article class="track">
            <span class="num">{tr.n}</span>
            <div><h3>{tr.t}</h3><p>{tr.d}</p></div>
            <span class="play">▶</span>
          </article>
        ))}
      </div>
    </section>

    <section id="about" class="panel stats-band">
      {stats.map((s) => (<div class="stat"><b>{s.n}</b><span>{s.l}</span></div>))}
    </section>

    <section class="cta">
      <h2>Готов в закат?</h2>
      <a class="btn btn-lg" href="#">Начать поездку →</a>
    </section>

    <footer>
      <span>NEON 2099 · synthwave mode</span>
      <a href="/">← на витрину</a>
    </footer>

    <style>
      :root { --neon: #ff2e97; --cyan: #00e5ff; }
      * { box-sizing: border-box; }
      body { margin: 0; min-height: 100vh; font-family: var(--font-sans); color: #fff;
        background: linear-gradient(180deg, #0d0221 0%, #2d0b4e 45%, #51136b 70%, #ff6b6b 120%); }
      .sun { position: fixed; top: 12%; left: 50%; transform: translateX(-50%); width: 300px; height: 300px; z-index: 0;
        border-radius: 50%; background: linear-gradient(180deg, #ffd166, #ff2e97); filter: blur(2px); box-shadow: 0 0 90px #ff2e97aa; }
      .sun::after { content:''; position:absolute; inset:0; border-radius:50%;
        background: repeating-linear-gradient(180deg, transparent 0 14px, #2d0b4e 14px 22px); mask: linear-gradient(180deg, transparent 55%, #000 55%); }
      .grid-floor { position: fixed; bottom: 0; left: -50%; width: 200%; height: 45%; z-index: 0;
        background-image: linear-gradient(#00e5ff55 1px, transparent 1px), linear-gradient(90deg, #00e5ff55 1px, transparent 1px);
        background-size: 44px 44px; transform: perspective(340px) rotateX(72deg); transform-origin: bottom; }
      .scanlines { position: fixed; inset: 0; pointer-events: none; z-index: 1;
        background: repeating-linear-gradient(180deg, rgba(0,0,0,.16) 0 2px, transparent 2px 4px); }
      nav, header, section, footer { position: relative; z-index: 2; }

      .btn { display: inline-block; background: var(--neon); color: #fff; text-decoration: none; font-weight: 700;
        padding: 11px 24px; border-radius: 999px; box-shadow: 0 0 22px var(--neon); border: 1px solid #ff8fc7; transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn-sm { padding: 8px 16px; font-size: .9rem; }
      .btn-lg { padding: 14px 30px; }
      .btn-ghost { background: transparent; box-shadow: none; border: 1px solid var(--cyan); color: var(--cyan); }

      .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 6vw; }
      .logo { font-weight: 900; font-size: 1.4rem; color: #fff; text-decoration: none; letter-spacing: .02em; }
      .logo span { color: var(--cyan); }
      .links { display: flex; align-items: center; gap: 24px; }
      .links a { color: #e7d9ff; text-decoration: none; font-family: var(--font-mono); font-size: .9rem; }

      .hero { max-width: 760px; margin: 0 auto; padding: 16vh 6vw 12vh; text-align: center; }
      .eyebrow { font-family: var(--font-mono); color: var(--cyan); letter-spacing: .35em; text-transform: uppercase; font-size: var(--fs-small); }
      .chrome { font-size: clamp(3rem, 12vw, 7rem); margin: var(--space-2) 0; letter-spacing: .04em; font-weight: 900;
        background: linear-gradient(180deg, #fff 0%, #c0c6ff 40%, #ff2e97 60%, #7a1f5a 100%);
        -webkit-background-clip: text; background-clip: text; color: transparent; text-shadow: 0 0 26px #ff2e9766; }
      .lead { color: #e7d9ff; max-width: 480px; margin: 0 auto var(--space-3); }
      .row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

      .panel { max-width: 900px; margin: 0 auto; padding: 6vh 6vw; }
      .panel h2 { font-size: clamp(1.8rem, 5vw, 2.6rem); text-align: center; margin: 0 0 var(--space-4);
        text-shadow: 0 0 18px var(--neon); }
      .tracks { display: grid; gap: 14px; }
      .track { display: grid; grid-template-columns: auto 1fr auto; gap: 18px; align-items: center;
        background: rgba(13,2,33,.55); border: 1px solid #ffffff22; border-radius: 14px; padding: 18px 22px; backdrop-filter: blur(6px); }
      .track:hover { border-color: var(--cyan); box-shadow: 0 0 22px #00e5ff44; }
      .num { font-family: var(--font-mono); color: var(--cyan); font-size: 1.2rem; }
      .track h3 { margin: 0; font-size: 1.2rem; }
      .track p { margin: 2px 0 0; color: #c9bce8; font-size: .9rem; }
      .play { color: var(--neon); font-size: 1.1rem; }
      .stats-band { display: flex; justify-content: center; gap: 60px; flex-wrap: wrap; }
      .stat { text-align: center; }
      .stat b { display: block; font-size: 2.4rem; font-weight: 900; color: #fff; text-shadow: 0 0 16px var(--cyan); }
      .stat span { font-family: var(--font-mono); color: #c9bce8; font-size: .85rem; text-transform: uppercase; letter-spacing: .1em; }

      .cta { text-align: center; padding: 8vh 6vw; }
      .cta h2 { font-size: clamp(1.8rem, 6vw, 3rem); margin: 0 0 var(--space-3); text-shadow: 0 0 18px var(--neon); }

      footer { display: flex; justify-content: space-between; align-items: center; max-width: 900px; margin: 0 auto;
        padding: 5vh 6vw; color: #c9bce8; font-family: var(--font-mono); font-size: .85rem; }
      footer a { color: var(--cyan); text-decoration: none; }
      @media (max-width: 640px){ .links a:not(.btn){ display:none; } }
    </style>
  </body>
</html>
