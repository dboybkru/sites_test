---
const base = import.meta.env.BASE_URL;
const clay = `${base}img/clay.webp`;
const cards = [
  { ic: '🫧', t: 'Мягкий старт', d: 'Никакого давления и красных стриков. Пропустил день — Сквиши просто обнимет.' },
  { ic: '🌈', t: 'Настроение', d: 'Отмечай, как день — одним тапом. Приложение учится твоему ритму.' },
  { ic: '🧸', t: 'Тёплые ачивки', d: 'За маленькие победы — милые персонажи, а не сухие галочки.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Squish — привычки, которые хочется тискать</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <a class="logo" href="#"><span class="dot"></span> Squish</a>
      <div class="links">
        <a href="#how">Как это</a>
        <a href="#" class="btn">Попробовать</a>
      </div>
    </nav>

    <header class="hero">
      <div class="copy">
        <span class="pill">✨ новый питомец привычек</span>
        <h1>Привычки, которые<br>хочется тискать</h1>
        <p class="lead">Squish превращает рутину в игру с мягкими 3D-друзьями. Без стресса, стриков и чувства вины — только тёплый прогресс.</p>
        <div class="cta">
          <a href="#" class="btn lg">Завести Сквиши</a>
          <a href="#how" class="btn lg soft">Как это работает</a>
        </div>
        <p class="users">🥹 уже тискают 120&nbsp;000 человек</p>
      </div>
      <figure class="hero-art">
        <img src={clay} alt="Мягкие 3D-клей-персонажи Squish" loading="eager" />
      </figure>
    </header>

    <section id="how" class="cards">
      {cards.map((c) => (
        <article class="claycard">
          <div class="emoji">{c.ic}</div>
          <h3>{c.t}</h3>
          <p>{c.d}</p>
        </article>
      ))}
    </section>

    <section class="band">
      <div class="band-inner">
        <h2>Заведи первого Сквиши за 30 секунд</h2>
        <a href="#" class="btn lg">Начать бесплатно</a>
      </div>
    </section>

    <footer class="foot">
      <p>Сделано мягко 🫶 · 2026</p>
      <a href="/">← на витрину</a>
    </footer>

    <style>
      :root {
        --bg: #efeafe; --ink: #5b4b6b; --pink: #f4a6c0; --blue: #a6c8f4; --yellow: #f9d29b;
        --r: 34px;
        --sh: 9px 9px 20px #ccc5ea, -9px -9px 20px #ffffff;
        --inset: inset 4px 4px 9px rgba(170,160,205,.45), inset -5px -5px 10px rgba(255,255,255,.85);
        --display: 'Baloo 2', system-ui, sans-serif; --body: 'Nunito', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--ink); font-family: var(--body); }
      .btn { display: inline-block; text-decoration: none; color: #fff; font-weight: 700; font-family: var(--display);
        background: linear-gradient(145deg,#f4a6c0,#e98bac); border-radius: 999px; padding: 12px 24px; box-shadow: var(--sh); transition: transform .15s; }
      .btn:hover { transform: translateY(-2px); }
      .btn:active { box-shadow: var(--inset); }
      .btn.lg { padding: 15px 32px; font-size: 1.05rem; }
      .btn.soft { background: linear-gradient(145deg,#fff,#ece6fb); color: var(--ink); }

      .nav { display: flex; justify-content: space-between; align-items: center; padding: 16px 5vw; }
      .logo { display: flex; align-items: center; gap: 10px; font-family: var(--display); font-weight: 800; font-size: 1.4rem; color: var(--ink); text-decoration: none; }
      .dot { width: 24px; height: 24px; border-radius: 50%; background: linear-gradient(145deg,#f4a6c0,#a6c8f4); box-shadow: var(--sh); }
      .links { display: flex; align-items: center; gap: 22px; }
      .links a:not(.btn) { color: var(--ink); text-decoration: none; font-weight: 700; }

      .hero { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; max-width: 1150px; margin: 0 auto; padding: 5vh 5vw 4vh; }
      .pill { display: inline-block; background: var(--bg); border-radius: 999px; padding: 9px 18px; box-shadow: var(--sh); font-weight: 700; font-size: .85rem; }
      h1 { font-family: var(--display); font-size: clamp(2.4rem, 6vw, 4rem); line-height: 1.04; margin: 20px 0; font-weight: 800; }
      .lead { font-size: 1.15rem; line-height: 1.65; max-width: 440px; color: #6e5e7e; }
      .cta { display: flex; gap: 16px; margin-top: 26px; flex-wrap: wrap; }
      .users { margin-top: 22px; font-weight: 700; color: #8a7c98; }
      .hero-art { margin: 0; background: var(--bg); border-radius: var(--r); padding: 18px; box-shadow: var(--sh); }
      .hero-art img { width: 100%; border-radius: calc(var(--r) - 14px); display: block; }

      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap: 28px; max-width: 1100px; margin: 0 auto; padding: 6vh 5vw; }
      .claycard { background: var(--bg); border-radius: var(--r); padding: 30px; box-shadow: var(--sh); }
      .emoji { width: 66px; height: 66px; display: grid; place-items: center; font-size: 2rem; border-radius: 22px; background: var(--bg); box-shadow: var(--inset); margin-bottom: 18px; }
      .claycard h3 { margin: 0 0 8px; font-family: var(--display); font-size: 1.4rem; }
      .claycard p { margin: 0; color: #6e5e7e; line-height: 1.6; }

      .band { padding: 4vh 5vw 8vh; }
      .band-inner { max-width: 880px; margin: 0 auto; background: linear-gradient(145deg,#f7d6e3,#e7dbfb); border-radius: 40px; box-shadow: var(--sh);
        padding: 56px 32px; text-align: center; }
      .band-inner h2 { font-family: var(--display); font-size: clamp(1.6rem,4vw,2.4rem); margin: 0 0 24px; }

      .foot { display: flex; justify-content: space-between; align-items: center; max-width: 1100px; margin: 0 auto; padding: 4vh 5vw; }
      .foot p { margin: 0; color: #8a7c98; font-weight: 700; }
      .foot a { color: #e98bac; text-decoration: none; font-weight: 800; font-family: var(--display); }

      @media (max-width: 780px){ .hero { grid-template-columns: 1fr; } .hero-art { order: -1; } .links a:not(.btn){ display: none; } }
    </style>
  </body>
</html>
