---
import '@lab/tokens/tokens.css';
import '@lab/motion/motion.css';
import { getSites } from '../sites.mjs';

const sites = getSites();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Дизайн-лаборатория · витрина</title>
    <meta name="description" content="Витрина дизайн-экспериментов: разные подходы, скилы и инструменты." />
  </head>
  <body>
    <main>
      <header class="hero m-fade-up">
        <p class="eyebrow">test_site_design</p>
        <h1>Дизайн-лаборатория</h1>
        <p class="lead">
          Витрина экспериментов: разные подходы к дизайну сайтов, разные скилы и инструменты.
          Каждая карточка — самодостаточный сайт.
        </p>
        <p class="count">{sites.length} {sites.length === 1 ? 'эксперимент' : 'экспериментов'}</p>
      </header>

      {sites.length === 0 ? (
        <p class="empty">Пока пусто. Создай первый сайт: <code>npm run new -- 02-name "Название"</code></p>
      ) : (
        <section class="grid m-stagger">
          {sites.map((s, i) => (
            <a class="card" href={s.href} style={`--accent:${s.accent}; --m-i:${i}`}>
              <div class="thumb"><span class="mono">/{s.slug}/</span></div>
              <div class="body">
                <div class="row">
                  <h2>{s.title}</h2>
                  <span class={`badge badge-${s.status}`}>{s.status}</span>
                </div>
                {s.description && <p class="desc">{s.description}</p>}
                <div class="tags">
                  {s.skill && <span class="tag">skill: {s.skill}</span>}
                  {s.tool && <span class="tag">{s.tool}</span>}
                </div>
              </div>
            </a>
          ))}
        </section>
      )}

      <footer>
        <span>Собрано через <code>npm run build:all</code> · деплой на Vercel</span>
      </footer>
    </main>

    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        background-image: radial-gradient(60% 50% at 50% 0%, rgba(139, 92, 246, 0.18), transparent 70%);
      }
      main { max-width: 1100px; margin: 0 auto; padding: var(--space-5) var(--space-3); }
      .hero { text-align: center; margin-bottom: var(--space-5); }
      .eyebrow { font-family: var(--font-mono); color: var(--color-accent-2); letter-spacing: 0.1em; margin: 0 0 var(--space-1); font-size: var(--fs-small); }
      h1 { font-size: var(--fs-1); margin: 0 0 var(--space-2); line-height: 1.05; }
      .lead { color: var(--color-text-dim); max-width: 560px; margin: 0 auto; font-size: var(--fs-3); }
      .count { font-family: var(--font-mono); color: var(--color-text-dim); font-size: var(--fs-small); margin-top: var(--space-3); }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-3); }
      .card {
        display: flex; flex-direction: column; text-decoration: none; color: inherit;
        background: var(--color-surface); border: 1px solid var(--color-border);
        border-radius: var(--radius-lg); overflow: hidden;
        transition: transform 0.3s var(--ease), border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
      }
      .card:hover { transform: translateY(-6px); border-color: var(--accent); box-shadow: 0 20px 50px -20px var(--accent); }
      .thumb {
        height: 150px; display: grid; place-items: center;
        background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 35%, var(--color-surface-2)), var(--color-surface-2));
      }
      .thumb .mono { font-family: var(--font-mono); color: var(--color-text); opacity: 0.7; }
      .body { padding: var(--space-3); }
      .row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-2); }
      h2 { font-size: var(--fs-3); margin: 0; }
      .desc { color: var(--color-text-dim); font-size: var(--fs-small); margin: var(--space-1) 0 var(--space-2); }
      .tags { display: flex; gap: var(--space-1); flex-wrap: wrap; }
      .tag { font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-text-dim); border: 1px solid var(--color-border); border-radius: 999px; padding: 2px 10px; }
      .badge { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; border-radius: 999px; padding: 3px 9px; }
      .badge-demo { background: rgba(34, 211, 238, 0.15); color: var(--color-accent-2); }
      .badge-wip { background: rgba(160, 160, 184, 0.15); color: var(--color-text-dim); }
      .badge-done { background: rgba(139, 92, 246, 0.18); color: var(--color-accent); }
      .empty { text-align: center; color: var(--color-text-dim); }
      code { font-family: var(--font-mono); background: var(--color-surface-2); padding: 2px 7px; border-radius: 6px; }
      footer { margin-top: var(--space-5); text-align: center; color: var(--color-text-dim); font-size: var(--fs-small); }
    </style>
  </body>
</html>
